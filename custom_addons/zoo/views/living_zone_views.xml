<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_living_zone_tree" model="ir.ui.view">
        <field name="name">zoo.living.zone.tree</field>
        <field name="model">zoo.living.zone</field>

        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="capacity"/>
                <field name="keeper_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_living_zone_form" model="ir.ui.view">
        <field name="name">zoo.living.zone.form</field>
        <field name="model">zoo.living.zone</field>

        <field name="arch" type="xml">
            <form string="Living Zone">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_animals"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-paw"
                        >
                            <field 
                                name="animal_count" 
                                widget="statinfo" 
                                string="Animals"
                            />
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="capacity"/>
                        </group>

                        <group>
                            <field name="keeper_id"/>
                        </group>
                    </group>

                    <group>
                        <field name="description"/>
                    </group>

                </sheet>

                <notebook>
                    <page string="Animals">
                        <field name="animal_ids">
                            <tree editable="bottom">
                                <field name="name"/>
                                <field name="species"/>
                                <field name="gender"/>
                                <field name="weight"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_living_zone" model="ir.actions.act_window">
        <field name="name">Living Zones</field>
        <field name="res_model">zoo.living.zone</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>