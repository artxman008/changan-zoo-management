<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_animal_tree" model="ir.ui.view">
        <field name="name">zoo.animal.tree</field>
        <field name="model">zoo.animal</field>

        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="species"/>
                <field name="gender"/>
                <field name="zone_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_animal_form" model="ir.ui.view">
        <field name="name">zoo.animal.form</field>
        <field name="model">zoo.animal</field>

        <field name="arch" type="xml">
            <form string="Animal">
                <sheet>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="species"/>
                            <field name="gender"/>
                        </group>

                        <group>
                            <field name="birth_date"/>
                            <field name="weight"/>
                            <field name="zone_id"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>

    </record>

    <!-- Search View -->
    <record id="view_animal_search" model="ir.ui.view">
        <field name="name">zoo.animal.search</field>
        <field name="model">zoo.animal</field>

        <field name="arch" type="xml">
            <search string="Search Animals">

                <!-- Search Fields -->
                <field name="name"/>
                <field name="species"/>
                <field name="zone_id"/>

                <separator/>

                <!-- Quick Filters -->
                <filter
                    name="filter_male"
                    string="Male"
                    domain="[('gender', '=', 'male')]"
                />

                <filter
                    name="filter_female"
                    string="Female"
                    domain="[('gender', '=', 'female')]"
                />

                <filter
                    name="filter_heavy"
                    string="Heavy Animals"
                    domain="[('weight', '>=', 100)]"
                />

                <separator/>

                <!-- Group By -->
                <group
                    expand="0"
                    string="Group By"
                >

                    <filter
                        name="group_by_zone"
                        string="Living Zone"
                        context="{'group_by': 'zone_id'}"
                    />

                    <filter
                        name="group_by_species"
                        string="Species"
                        context="{'group_by': 'species'}"
                    />

                </group>

            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_animal" model="ir.actions.act_window">
        <field name="name">Animals</field>
        <field name="res_model">zoo.animal</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_animal_search"/>
    </record>

</odoo>