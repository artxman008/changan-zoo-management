<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_animal_tree" model="ir.ui.view">
        <field name="name">zoo.animal.tree</field>
        <field name="model">zoo.animal</field>

        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="species"/>
                <field name="gender"/>
                <field name="zone_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_animal_form" model="ir.ui.view">
        <field name="name">zoo.animal.form</field>
        <field name="model">zoo.animal</field>

        <field name="arch" type="xml">
            <form string="Animal">
                <sheet>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="species"/>
                            <field name="gender"/>
                        </group>

                        <group>
                            <field name="birth_date"/>
                            <field name="weight"/>
                            <field name="zone_id"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>

    </record>

    <!-- Action -->
    <record id="action_animal" model="ir.actions.act_window">
        <field name="name">Animals</field>
        <field name="res_model">zoo.animal</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>